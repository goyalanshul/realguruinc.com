  <header id="top" class="hero-section">
    <div class="hero-orb hero-orb-one"></div>
    <div class="hero-orb hero-orb-two"></div>
    <div class="container position-relative">
      <div class="row align-items-center g-5">
        <div class="col-lg-7">
          <div class="eyebrow">Launching Soon | Limited Pre-Launch Inventory</div>
          <h1>Luxury residences rising on the Ambala-Chandigarh Expressway.</h1>
          <p class="hero-copy">
            A premium S+14 apartment address designed for end users and investors who want scale, location advantage, and a polished lifestyle offering on NH-152.
          </p>
          <div class="hero-actions">
            <a class="btn btn-gold" href="#contact">Book a Site Discussion</a>
            <a class="btn btn-outline-light" href="#plans">See Unit Options</a>
          </div>
          <div class="hero-metrics">
            <div class="metric-card">
              <span class="metric-value">S+14</span>
              <span class="metric-label">Stilt + 14 floors</span>
            </div>
            <div class="metric-card">
              <span class="metric-value">3 &amp; 4 BHK</span>
              <span class="metric-label">Luxury layouts</span>
            </div>
            <div class="metric-card">
              <span class="metric-value">NH-152</span>
              <span class="metric-label">Prime expressway address</span>
            </div>
          </div>
        </div>
        <div class="col-lg-5">
          <div class="tower-stage">
            <div class="tower-cluster">
              <div class="tower tower-a"></div>
              <div class="tower tower-b"></div>
              <div class="tower tower-c"></div>
              <div class="tower tower-d"></div>
            </div>
            <div class="launch-card">
              <div class="launch-card-top">
                <span class="launch-chip">Soft Launch Offer</span>
                <span class="launch-chip launch-chip-outline">Mivan Technology</span>
              </div>

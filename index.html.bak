            <div class="plan-meta">
              <div>
                <span class="meta-label">Booking Amount</span>
                <span class="meta-value">Rs 15 Lakhs</span>
              </div>
              <div>
                <span class="meta-label">Ideal For</span>
                <span class="meta-value">Luxury families, investor showcase stock</span>
              </div>
            </div>
          </article>
        </div>
      </div>
      <div class="launch-strip">

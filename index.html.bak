                <span>Leading multispeciality hospital</span>
              </div>
              <div class="landmark-item">
                <strong>Adjacent</strong>
                <span>International school campus</span>
              </div>
              <div class="landmark-item">
                <strong>Opposite</strong>
                <span>Well-known K-12 school</span>
              </div>
              <div class="landmark-item">
                <strong>Opposite</strong>
                <span>Established residential township</span>
              </div>
            </div>
